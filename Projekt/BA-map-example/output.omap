                    <area_symbol inner_color="2" min_area="0" patterns="0"/>
                  </symbol>
                  <object type="1">
                    <coords count="4">-125 125;125 125;125 -125;-125 -125;</coords>
                    <pattern rotation="0">
                      <coord x="0" y="0"/>
                    </pattern>
                  </object>
                </element>
              </point_symbol>
            </symbol>
          </mid_symbol>
        </line_symbol>
      </symbol>
      
      <symbol code="519" id="102" name="Passable stone wall" type="2">
        <description>A stone wall or stone faced bank. This symbol shall be used only in non-urban areas. If such a wall is higher than 2 m, it shall be represented with the symbol impassable wall (521.1).</description>
        <line_symbol break_length="1000" cap_style="0" color="2" dash_length="4000" dashes_in_group="1" end_length="1875" end_offset="0" in_group_break_length="500" join_style="1" line_width="210" mid_symbol_distance="0" mid_symbols_per_spot="1" minimum_length="0" minimum_mid_symbol_count="0" minimum_mid_symbol_count_when_closed="0" segment_length="3750" show_at_least_one_symbol="true" start_offset="0">
          <mid_symbol>
            <symbol code="" name="Mid symbol" type="1">
              <point_symbol elements="0" inner_color="2" inner_radius="300" outer_color="-1" outer_width="0" rotatable="true"/>
            </symbol>
          </mid_symbol>
        </line_symbol>
      </symbol>
      
      <symbol code="519.1.1" id="103" name="Passable wall" type="2">
        <description>A passable wall or retaining wall is a construction made of stone, brick, concrete etc., which can be passed. This symbol is suitable for urban areas. If such a wall is higher than 2 m, it shall be represented with the symbol impassable wall (521.1). Wide walls shall be drawn in plan shape.</description>
        <line_symbol break_length="1000" cap_style="0" color="7" dash_length="4000" dashes_in_group="1" end_length="0" end_offset="0" in_group_break_length="500" join_style="1" line_width="350" mid_symbol_distance="0" mid_symbols_per_spot="1" minimum_length="0" minimum_mid_symbol_count="0" minimum_mid_symbol_count_when_closed="0" segment_length="0" show_at_least_one_symbol="true" start_offset="0"/>
      </symbol>
      
      <symbol code="519.1.2" id="104" name="Passable wall, plan shape" type="4">
        <description>A passable wall or retaining wall is a construction made of stone, brick, concrete etc., which can be passed. This symbol is suitable for urban areas. If such a wall is higher than 2 m, it shall be represented with the symbol (521.1). Wide walls shall be drawn in plan shape.</description>
        <area_symbol inner_color="7" min_area="500" patterns="0"/>
      </symbol>
      
      <symbol code="521.1.1" id="105" name="Impassable wall &lt;span style=&quot;color:magenta&quot;&gt;(forbidden to cross)&lt;/span&gt;" type="2">
        <description>An impassable wall or retaining wall is a wall, which fulfill the function of an enclosure or solid barrier. It shall not be crossed, due to forbidden access or because it may constitute a danger to the competitor due to its height. Very wide impassable walls shall be drawn in plan shape and represented with the symbol building (526.1).

&lt;span style="color:magenta"&gt;It is forbidden to cross an impassable wall!
Competitors violating this rule will be disqualified.&lt;/span&gt;</description>
        <line_symbol break_length="1000" cap_style="0" color="2" dash_length="4000" dashes_in_group="1" end_length="0" end_offset="0" in_group_break_length="500" join_style="1" line_width="400" mid_symbol_distance="0" mid_symbols_per_spot="1" minimum_length="0" minimum_mid_symbol_count="0" minimum_mid_symbol_count_when_closed="0" segment_length="0" show_at_least_one_symbol="true" start_offset="0"/>
      </symbol>
      
      <symbol code="521.1.2" id="106" name="Impassable wall, plan shape &lt;span style=&quot;color:magenta&quot;&gt;(forbidden to cross)&lt;/span&gt;" type="4">
        <description>An impassable wall or retaining wall is a wall, which fulfill the function of an enclosure or solid barrier. It shall not be crossed, due to forbidden access or because it may constitute a danger to the competitor due to its height. Very wide impassable walls shall be drawn in plan shape and represented with the symbol building (526.1).

&lt;span style="color:magenta"&gt;It is forbidden to cross an impassable wall!
Competitors violating this rule will be disqualified.&lt;/span&gt;</description>
        <area_symbol inner_color="2" min_area="500" patterns="0"/>
      </symbol>
      
      <symbol code="522" id="107" name="Passable fence or railing" type="2">
        <description>A passable fence is a barrier enclosing or bordering a field, yard, etc., usually made of posts and wire or wood. It is used to prevent entrance or to confine or mark a boundary. A railing is a fencelike barrier composed of one or more horizontal rails supported by widely spaced upright poles, usually it can be slipped through.

If a fence or railing is higher than 2 m or very difficult to cross, it shall be represented with the symbol impassable fence or railing (524).</description>
