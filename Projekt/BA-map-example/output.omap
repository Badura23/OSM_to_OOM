        </text_symbol>
      </symbol>
      
      <symbol code="701" id="153" name="Start" type="1">
        <description>The start or map issue point (if not at the start) is shown by an equilateral triangle which points in the direction of the first control. The centre of the triangle shows the precise position of the start point.</description>
        <point_symbol elements="1" inner_color="-1" inner_radius="1000" outer_color="-1" outer_width="0" rotatable="true">
