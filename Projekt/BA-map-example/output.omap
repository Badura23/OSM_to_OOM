      <symbol code="515.2" id="98" name="Tramway" type="2">
        <description>A tramway is a public vehicle running regularly along certain streets, usually on rails. The track can be easily crossed by the competitor. Tramways are generally not represented. However, if they serve navigation or orientation, they can be represented.</description>
        <line_symbol break_length="1000" cap_style="0" color="-1" dash_length="1500" dashes_in_group="1" end_length="1500" end_offset="0" in_group_break_length="500" join_style="1" line_width="300" mid_symbol_distance="0" mid_symbols_per_spot="1" minimum_length="0" minimum_mid_symbol_count="0" minimum_mid_symbol_count_when_closed="0" segment_length="3000" show_at_least_one_symbol="true" start_offset="0">
          <borders>
            <border color="7" shift="0" width="100"/>
          </borders>
        </line_symbol>
      </symbol>
      
      <symbol code="516" id="99" name="Power line, cableway or skilift" type="2">
        <description>Power line, cableway or skilift. The bars indicate the exact location of the pylons.

&lt;b&gt;Note: When drawing this symbol, press space to toggle placing the pylon symbols at new nodes.&lt;/b&gt;</description>
        <line_symbol break_length="1000" cap_style="0" color="2" dash_length="4000" dashes_in_group="1" end_length="0" end_offset="0" in_group_break_length="500" join_style="1" line_width="140" mid_symbol_distance="0" mid_symbols_per_spot="1" minimum_length="0" minimum_mid_symbol_count="0" minimum_mid_symbol_count_when_closed="0" segment_length="4000" show_at_least_one_symbol="true" start_offset="0">
