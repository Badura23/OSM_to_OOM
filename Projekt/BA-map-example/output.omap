      </symbol>
      
      <symbol code="106.2" id="7" name="Earth bank, tag line" type="2">
        <description>Use this symbol to display the full extent of wide earth banks.</description>
        <line_symbol break_length="1000" cap_style="0" color="23" dash_length="4000" dashes_in_group="1" end_length="0" end_offset="0" in_group_break_length="500" join_style="1" line_width="210" mid_symbol_distance="0" mid_symbols_per_spot="1" minimum_length="645" minimum_mid_symbol_count="0" minimum_mid_symbol_count_when_closed="0" segment_length="4000" show_at_least_one_symbol="true" start_offset="0"/>
      </symbol>
      
      <symbol code="108.1" id="8" name="Small earth wall" type="2">
        <description>A small distinct earth wall, usually man made. The minimum height is 0.5 m. Larger earth walls should be represented with the symbols contour (101), form line (103) or earth bank (106).</description>
        <line_symbol break_length="1000" cap_style="0" color="23" dash_length="4000" dashes_in_group="1" end_length="1875" end_offset="0" in_group_break_length="500" join_style="2" line_width="210" mid_symbol_distance="0" mid_symbols_per_spot="1" minimum_length="0" minimum_mid_symbol_count="0" minimum_mid_symbol_count_when_closed="0" segment_length="3750" show_at_least_one_symbol="true" start_offset="0">
          <mid_symbol>
            <symbol code="" name="Mid symbol" type="1">
              <point_symbol elements="0" inner_color="23" inner_radius="300" outer_color="-1" outer_width="0" rotatable="true"/>
            </symbol>
          </mid_symbol>
        </line_symbol>
      </symbol>
      
      <symbol code="109" id="9" name="Erosion gully or trench" type="2">
        <description>An erosion gully or trench which is too small to be represented with the symbol earth bank (106), contour (101), index contour (102) or form line (103) is represented by a single line. The line width reflects the size of the gully. The end of the line is pointed. Minimum depth is 1 m. Minimum length is 3 mm on the map.</description>
        <line_symbol break_length="1000" cap_style="3" color="23" dash_length="4000" dashes_in_group="1" end_length="0" end_offset="750" in_group_break_length="500" join_style="2" line_width="370" mid_symbol_distance="0" mid_symbols_per_spot="1" minimum_length="3000" minimum_mid_symbol_count="0" minimum_mid_symbol_count_when_closed="0" pointed_cap_length="750" segment_length="4000" show_at_least_one_symbol="true" start_offset="750"/>
      </symbol>
      
      <symbol code="110" id="10" name="Small erosion gully" type="2">
        <description>A small erosion gully or trench. Minimum depth is 0.5 m.</description>
        <line_symbol break_length="1000" cap_style="0" color="2" dash_length="4000" dashes_in_group="1" end_length="0" end_offset="0" in_group_break_length="500" join_style="1" line_width="0" mid_symbol_distance="0" mid_symbols_per_spot="1" minimum_length="0" minimum_mid_symbol_count="0" minimum_mid_symbol_count_when_closed="0" segment_length="600" show_at_least_one_symbol="true" start_offset="0">
