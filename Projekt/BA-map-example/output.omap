      <symbol code="603.0.1" id="151" name="Spot height, dot" type="1">
        <description>Spot heights are used for the rough assessment of height differences. The height is given to the nearest metre. The figures are orientated to the north. Water levels are given without the dot.</description>
        <point_symbol elements="0" inner_color="2" inner_radius="150" outer_color="-1" outer_width="0"/>
      </symbol>
      
      <symbol code="603.0.2" id="152" name="Spot height" type="8">
