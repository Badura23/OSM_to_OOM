      </symbol>
      
      <symbol code="401" id="62" name="Open land" type="4">
        <description>An area of cultivated land, lawn, field, meadow, grassland, etc. without trees, offering very good runnability.</description>
        <area_symbol inner_color="34" min_area="500" patterns="0"/>
      </symbol>
      
      <symbol code="402" id="63" name="Open land with scattered trees" type="4">
        <description>An area of meadows with scattered trees or bushes, with grass or similar ground cover offering very good runnability. Areas smaller than 10 mm² at the maps scale are shown as open land (401). Symbols prominent large tree (418) and prominent bush or small tree (419) may be added.</description>
        <area_symbol inner_color="-1" min_area="10000" patterns="1">
          <pattern angle="0.785398" line_offset="0" line_spacing="500" offset_along_line="0" point_distance="500" type="2">
            <symbol code="" name="Pattern fill 1" type="1">
              <point_symbol elements="0" inner_color="34" inner_radius="200" outer_color="-1" outer_width="0" rotatable="true"/>
            </symbol>
          </pattern>
        </area_symbol>
      </symbol>
      
      <symbol code="403" id="64" name="Rough open land" type="4">
        <description>An area of heath or moorland, a felled area, a newly planted area (trees lower than ca. 1 m) or other generally open land with rough ground vegetation, i.e. heather or tall grass. This symbol may be combined with symbols undergrowth: slow running (407) and undergrowth: difficult to run (409) to show reduced runnability.</description>
        <area_symbol inner_color="35" min_area="1000" patterns="0"/>
      </symbol>
      
      <symbol code="404" id="65" name="Rough open land with scattered trees" type="4">
        <description>An area of rough open land with scattered trees or bushes. Areas smaller than 16 mm² in the map scale are either mapped as rough open land (403) or forest: easy running (405). Symbols prominent large tree (418) and prominent bush or small tree (419) may be added.</description>
        <area_symbol inner_color="37" min_area="16000" patterns="1">
          <pattern angle="0.785398" line_offset="0" line_spacing="700" offset_along_line="0" point_distance="700" type="2">
            <symbol code="" name="Pattern fill 1" type="1">
              <point_symbol elements="0" inner_color="36" inner_radius="275" outer_color="-1" outer_width="0" rotatable="true"/>
            </symbol>
          </pattern>
        </area_symbol>
      </symbol>
      
      <symbol code="405" id="66" name="Forest: easy running" type="4">
        <description>An area of typical open runnable forest for the particular type of terrain. If no part of the forest is runnable then no white should appear on the map.</description>
        <area_symbol inner_color="27" min_area="500" patterns="0"/>
      </symbol>
      
      <symbol code="406" id="67" name="Forest: slow running" type="4">
        <description>An area with dense trees (low visibility) which reduces running to ca. 60-80% of normal speed.

Minimum width 0.25 mm.</description>
        <area_symbol inner_color="32" min_area="1000" patterns="0"/>
      </symbol>
      
      <symbol code="406.1" id="68" name="Forest: slow running, minimum width" type="2">
        <line_symbol break_length="1000" cap_style="0" color="32" dash_length="4000" dashes_in_group="1" end_length="0" end_offset="0" in_group_break_length="500" join_style="1" line_width="250" mid_symbol_distance="0" mid_symbols_per_spot="1" minimum_length="0" minimum_mid_symbol_count="0" minimum_mid_symbol_count_when_closed="0" segment_length="4000" show_at_least_one_symbol="true" start_offset="0"/>
      </symbol>
      
      <symbol code="407" id="69" name="Undergrowth: slow running" type="4">
        <description>An area of dense undergrowth but otherwise good visibility (brambles, heather, low bushes, cut branches, etc.) which reduces running to ca. 60-80% of normal speed. This symbol shall not be combined with the symbol forest: slow running (406) or forest: difficult to run (408).</description>
        <area_symbol inner_color="-1" min_area="0" patterns="1">
          <pattern angle="1.5708" color="33" line_offset="0" line_spacing="840" line_width="120" offset_along_line="0" type="1"/>
        </area_symbol>
      </symbol>
      
      <symbol code="408" id="70" name="Forest: difficult to run" type="4">
        <description>An area with dense trees or thicket (low visibility) which reduces running to ca. 20-60% of normal speed.</description>
        <area_symbol inner_color="31" min_area="1000" patterns="0"/>
      </symbol>
      
      <symbol code="408.1" id="71" name="Forest: difficult to run, minimum width" type="2">
        <line_symbol break_length="1000" cap_style="0" color="31" dash_length="4000" dashes_in_group="1" end_length="0" end_offset="0" in_group_break_length="500" join_style="1" line_width="250" mid_symbol_distance="0" mid_symbols_per_spot="1" minimum_length="0" minimum_mid_symbol_count="0" minimum_mid_symbol_count_when_closed="0" segment_length="4000" show_at_least_one_symbol="true" start_offset="0"/>
      </symbol>
      
      <symbol code="409" id="72" name="Undergrowth: difficult to run" type="4">
        <description>An area of dense undergrowth but otherwise good visibility (brambles, heather, low bushes, and including cut branches) which reduces running to ca. 20-60% of normal speed. This symbol may not be combined with 406 or 408.</description>
        <area_symbol inner_color="-1" min_area="0" patterns="1">
          <pattern angle="1.5708" color="33" line_offset="0" line_spacing="420" line_width="120" offset_along_line="0" type="1"/>
        </area_symbol>
      </symbol>
      
      <symbol code="410" id="73" name="Vegetation: very difficult to run" type="4">
        <description>An area of dense vegetation (trees or undergrowth) which is barely passable. Running reduced 1-20% of normal speed. 

Minimum width: 0.25 mm.</description>
        <area_symbol inner_color="29" min_area="500" patterns="0"/>
      </symbol>
      
      <symbol code="410.1" id="74" name="Vegetation, very difficult to run, minimum width (hedge)" type="2">
        <line_symbol break_length="1000" cap_style="0" color="13" dash_length="4000" dashes_in_group="1" end_length="0" end_offset="0" in_group_break_length="500" join_style="1" line_width="250" mid_symbol_distance="0" mid_symbols_per_spot="1" minimum_length="0" minimum_mid_symbol_count="0" minimum_mid_symbol_count_when_closed="0" segment_length="4000" show_at_least_one_symbol="true" start_offset="0"/>
      </symbol>
      
      <symbol code="411.1" id="75" name="Forest (406) runnable in one direction" type="4">
        <description>When an area of forest provides good running in one direction but less good in others, white stripes are left in the screen symbol (406) to show the direction with good runnability.</description>
        <area_symbol inner_color="32" min_area="1000" patterns="1">
          <pattern angle="1.5708" color="27" line_offset="0" line_spacing="1500" line_width="400" offset_along_line="0" rotatable="true" type="1"/>
        </area_symbol>
      </symbol>
      
      <symbol code="411.2" id="76" name="Forest (408) runnable in one direction" type="4">
        <description>When an area of forest provides good running in one direction but less good in others, white stripes are left in the screen symbol (408) to show the direction with good runnability.</description>
        <area_symbol inner_color="31" min_area="1000" patterns="1">
          <pattern angle="1.5708" color="27" line_offset="0" line_spacing="1500" line_width="400" offset_along_line="0" rotatable="true" type="1"/>
        </area_symbol>
      </symbol>
      
      <symbol code="411.3" id="77" name="Forest (410) runnable in one direction" type="4">
        <description>When an area of forest provides good running in one direction but less good in others, white stripes are left in the screen symbol (410) to show the direction with good runnability.</description>
        <area_symbol inner_color="29" min_area="1000" patterns="1">
          <pattern angle="1.5708" color="27" line_offset="0" line_spacing="1500" line_width="400" offset_along_line="0" rotatable="true" type="1"/>
        </area_symbol>
      </symbol>
      
      <symbol code="412" id="78" name="Orchard" type="4">
        <description>Land planted with fruit trees or bushes. The dot lines may be orientated to represent the direction of planting.</description>
        <area_symbol inner_color="34" min_area="500" patterns="1">
          <pattern angle="0" line_offset="0" line_spacing="800" offset_along_line="0" point_distance="800" rotatable="true" type="2">
            <symbol code="" name="Pattern fill 1" type="1">
              <point_symbol elements="0" inner_color="30" inner_radius="225" outer_color="-1" outer_width="0" rotatable="true"/>
            </symbol>
          </pattern>
        </area_symbol>
      </symbol>
      
      <symbol code="413" id="79" name="Orchard, one direction (e.g. Vineyard)" type="4">
        <description>Land planted with fruit trees or bushes, with a distinct direction of planting which reduces the runnability. The green lines shall be orientated to show the direction of planting.</description>
        <area_symbol inner_color="34" min_area="500" patterns="2">
          <pattern angle="1.5708" line_offset="0" line_spacing="1700" offset_along_line="0" point_distance="1900" rotatable="true" type="2">
            <symbol code="" name="Pattern fill 1" type="1">
              <point_symbol elements="1" inner_color="-1" inner_radius="0" outer_color="-1" outer_width="0" rotatable="true">
                <element>
                  <symbol code="" type="2">
                    <line_symbol break_length="1000" cap_style="0" color="30" dash_length="4000" dashes_in_group="1" end_length="0" end_offset="0" in_group_break_length="500" join_style="1" line_width="200" mid_symbol_distance="0" mid_symbols_per_spot="1" minimum_length="0" minimum_mid_symbol_count="0" minimum_mid_symbol_count_when_closed="0" segment_length="4000" show_at_least_one_symbol="true" start_offset="0"/>
                  </symbol>
                  <object type="1">
                    <coords count="2">0 -650;0 650;</coords>
                    <pattern rotation="0">
                      <coord x="0" y="0"/>
                    </pattern>
                  </object>
                </element>
              </point_symbol>
            </symbol>
          </pattern>
          <pattern angle="1.5708" line_offset="850" line_spacing="1700" offset_along_line="950" point_distance="1900" rotatable="true" type="2">
            <symbol code="" name="Pattern fill 2" type="1">
              <point_symbol elements="1" inner_color="-1" inner_radius="1000" outer_color="-1" outer_width="0" rotatable="true">
                <element>
                  <symbol code="" type="2">
                    <line_symbol break_length="1000" cap_style="0" color="30" dash_length="4000" dashes_in_group="1" end_length="0" end_offset="0" in_group_break_length="500" join_style="1" line_width="200" mid_symbol_distance="0" mid_symbols_per_spot="1" minimum_length="0" minimum_mid_symbol_count="0" minimum_mid_symbol_count_when_closed="0" segment_length="4000" show_at_least_one_symbol="true" start_offset="0"/>
                  </symbol>
                  <object type="1">
                    <coords count="2">0 -650;0 650;</coords>
                    <pattern rotation="0">
                      <coord x="0" y="0"/>
                    </pattern>
                  </object>
                </element>
              </point_symbol>
            </symbol>
          </pattern>
        </area_symbol>
      </symbol>
      
      <symbol code="414" id="80" name="Distinct cultivation boundary" type="2">
        <description>The boundary of symbol cultivated land (seasonally out of bounds) (415) when not shown with other symbols (fence, wall, path, etc.) is represented with a black line. A permanent boundary between different types of cultivated land is also represented with this symbol.</description>
        <line_symbol break_length="1000" cap_style="0" color="2" dash_length="4000" dashes_in_group="1" end_length="0" end_offset="0" in_group_break_length="500" join_style="1" line_width="70" mid_symbol_distance="0" mid_symbols_per_spot="1" minimum_length="0" minimum_mid_symbol_count="0" minimum_mid_symbol_count_when_closed="0" segment_length="4000" show_at_least_one_symbol="true" start_offset="0"/>
      </symbol>
      
      <symbol code="415" id="81" name="Cultivated land (seasonally out of bounds)" type="4">
        <description>Cultivated land which is seasonally out-of-bounds due to growing crops may be shown with a black dot screen.</description>
        <area_symbol inner_color="34" min_area="500" patterns="1">
          <pattern angle="0" line_offset="0" line_spacing="800" offset_along_line="0" point_distance="800" type="2">
            <symbol code="" name="Pattern fill 1" type="1">
              <point_symbol elements="0" inner_color="2" inner_radius="100" outer_color="-1" outer_width="0" rotatable="true"/>
            </symbol>
          </pattern>
        </area_symbol>
      </symbol>
      
      <symbol code="416" id="82" name="Distinct vegetation boundary" type="2">
        <description>A distinct forest edge or very distinct vegetation boundary within the forest. For indistinct boundaries, the area edges are shown only by the change in colour and/or dot screen.</description>
        <line_symbol break_length="1000" cap_style="0" color="2" dash_length="4000" dashes_in_group="1" end_length="0" end_offset="0" in_group_break_length="500" join_style="1" line_width="0" mid_symbol_distance="0" mid_symbols_per_spot="1" minimum_length="220" minimum_mid_symbol_count="2" minimum_mid_symbol_count_when_closed="5" segment_length="600" show_at_least_one_symbol="true" start_offset="0">
          <mid_symbol>
            <symbol code="" name="Mid symbol" type="1">
              <point_symbol elements="0" inner_color="2" inner_radius="125" outer_color="-1" outer_width="0" rotatable="true"/>
            </symbol>
          </mid_symbol>
        </line_symbol>
      </symbol>
      
      <symbol code="418" id="83" name="Prominent large tree" type="1">
        <description>A prominent single tree.</description>
        <point_symbol elements="0" inner_color="-1" inner_radius="350" outer_color="13" outer_width="250"/>
      </symbol>
      
      <symbol code="419" id="84" name="Prominent bush or small tree" type="1">
        <description>A bush or a tree with a trunk less than 0.5 m diameter.</description>
        <point_symbol elements="0" inner_color="13" inner_radius="375" outer_color="-1" outer_width="0"/>
      </symbol>
      
      <symbol code="420" id="85" name="Prominent vegetation feature" type="1">
        <description>A vegetation feature which is significant or prominent. The definition of the symbol shall always be given in the map legend. The symbol is orientated to north.</description>
        <point_symbol elements="2" inner_color="-1" inner_radius="1000" outer_color="-1" outer_width="0">
          <element>
            <symbol code="" type="2">
              <line_symbol break_length="1000" cap_style="0" color="13" dash_length="4000" dashes_in_group="1" end_length="0" end_offset="0" in_group_break_length="500" join_style="1" line_width="250" mid_symbol_distance="0" mid_symbols_per_spot="1" minimum_length="0" minimum_mid_symbol_count="0" minimum_mid_symbol_count_when_closed="0" segment_length="4000" show_at_least_one_symbol="true" start_offset="0"/>
            </symbol>
            <object type="1">
              <coords count="2">-600 -600;600 600;</coords>
              <pattern rotation="0">
                <coord x="0" y="0"/>
              </pattern>
            </object>
          </element>
          <element>
            <symbol code="" type="2">
              <line_symbol break_length="1000" cap_style="0" color="13" dash_length="4000" dashes_in_group="1" end_length="0" end_offset="0" in_group_break_length="500" join_style="1" line_width="250" mid_symbol_distance="0" mid_symbols_per_spot="1" minimum_length="0" minimum_mid_symbol_count="0" minimum_mid_symbol_count_when_closed="0" segment_length="4000" show_at_least_one_symbol="true" start_offset="0"/>
            </symbol>
            <object type="1">
              <coords count="2">-600 600;600 -600;</coords>
              <pattern rotation="0">
                <coord x="0" y="0"/>
              </pattern>
            </object>
          </element>
        </point_symbol>
      </symbol>
      
      <symbol code="421" id="86" name="Impassable vegetation &lt;span style=&quot;color:magenta&quot;&gt;(forbidden to cross)&lt;/span&gt;" type="4">
        <description>An area of dense vegetation (trees or undergrowth) which is impassable or which shall not be crossed, due to forbidden access or because it may constitute a danger to the competitor.
 
Minimum width: 0.4 mm.

&lt;span style="color:magenta"&gt;It is forbidden to cross impassable vegetation!
Competitors violating this rule will be disqualified.&lt;/span&gt;</description>
        <area_symbol inner_color="28" min_area="500" patterns="0"/>
      </symbol>
      
      <symbol code="421.1" id="87" name="Impassable vegetation, minimum width (hedge)" type="2">
        <line_symbol break_length="1000" cap_style="0" color="10" dash_length="4000" dashes_in_group="1" end_length="0" end_offset="0" in_group_break_length="500" join_style="1" line_width="400" mid_symbol_distance="0" mid_symbols_per_spot="1" minimum_length="0" minimum_mid_symbol_count="0" minimum_mid_symbol_count_when_closed="0" segment_length="4000" show_at_least_one_symbol="true" start_offset="0"/>
      </symbol>
      
      <symbol code="506.1.1" id="88" name="Unpaved footpath or track, urban, minimum width" type="2">
        <description>An unpaved footpath or rough vehicle track is a way for passing mainly by foot, without a smooth, hard surface. The density of the brown fill-in shall be the same as the density chosen for the symbol (529).

To improve the legibility of this symbol in non-urban parts of the map, the line width shall, in the non-urban parts of the map, be increased from 0.07 mm to 0.14 mm, and the brown fill-in shall, in the non-urban parts of the map, be drawn darker, so that if (x)% brown is used in urban parts of the map, (x+20)% brown shall be used in the non-urban parts of the map.

Colour: black, brown 0%(white), 10%, 20% or 30% (urban) / 20%, 30%, 40%, 50% (min.60lines/cm) (non-urban); the colour and the line width shall be the same as for the symbols paved area (529) and step or edge of paved areas (529.1).</description>
        <line_symbol break_length="250" cap_style="0" color="15" dash_length="2000" dashes_in_group="1" end_length="0" end_offset="0" in_group_break_length="500" join_style="1" line_width="350" mid_symbol_distance="0" mid_symbols_per_spot="1" minimum_length="0" minimum_mid_symbol_count="0" minimum_mid_symbol_count_when_closed="0" segment_length="4000" show_at_least_one_symbol="true" start_offset="0">
          <borders>
            <border break_length="250" color="16" dash_length="2000" dashed="true" shift="35" width="70"/>
          </borders>
        </line_symbol>
      </symbol>
      
      <symbol code="506.1.2" id="89" name="Unpaved footpath or track, urban, 0.55mm width" type="2">
        <description>An unpaved footpath or rough vehicle track is a way for passing mainly by foot, without a smooth, hard surface. The density of the brown fill-in shall be the same as the density chosen for the symbol (529).

To improve the legibility of this symbol in non-urban parts of the map, the line width shall, in the non-urban parts of the map, be increased from 0.07 mm to 0.14 mm, and the brown fill-in shall, in the non-urban parts of the map, be drawn darker, so that if (x)% brown is used in urban parts of the map, (x+20)% brown shall be used in the non-urban parts of the map.

Colour: black, brown 0%(white), 10%, 20% or 30% (urban) / 20%, 30%, 40%, 50% (min.60lines/cm) (non-urban); the colour and the line width shall be the same as for the symbols paved area (529) and step or edge of paved areas (529.1).</description>
        <line_symbol break_length="250" cap_style="0" color="15" dash_length="2000" dashes_in_group="1" end_length="0" end_offset="0" in_group_break_length="500" join_style="1" line_width="550" mid_symbol_distance="0" mid_symbols_per_spot="1" minimum_length="0" minimum_mid_symbol_count="0" minimum_mid_symbol_count_when_closed="0" segment_length="4000" show_at_least_one_symbol="true" start_offset="0">
          <borders>
            <border break_length="250" color="16" dash_length="2000" dashed="true" shift="35" width="70"/>
          </borders>
        </line_symbol>
      </symbol>
      
      <symbol code="506.1.3" id="90" name="Unpaved footpath or track, non-urban, minimum width" type="2">
        <description>An unpaved footpath or rough vehicle track is a way for passing mainly by foot, without a smooth, hard surface. The density of the brown fill-in shall be the same as the density chosen for the symbol (529).

To improve the legibility of this symbol in non-urban parts of the map, the line width shall, in the non-urban parts of the map, be increased from 0.07 mm to 0.14 mm, and the brown fill-in shall, in the non-urban parts of the map, be drawn darker, so that if (x)% brown is used in urban parts of the map, (x+20)% brown shall be used in the non-urban parts of the map.

Colour: black, brown 0%(white), 10%, 20% or 30% (urban) / 20%, 30%, 40%, 50% (min.60lines/cm) (non-urban); the colour and the line width shall be the same as for the symbols paved area (529) and step or edge of paved areas (529.1).</description>
        <line_symbol break_length="250" cap_style="0" color="14" dash_length="2000" dashes_in_group="1" end_length="0" end_offset="0" in_group_break_length="500" join_style="1" line_width="350" mid_symbol_distance="0" mid_symbols_per_spot="1" minimum_length="0" minimum_mid_symbol_count="0" minimum_mid_symbol_count_when_closed="0" segment_length="4000" show_at_least_one_symbol="true" start_offset="0">
          <borders>
            <border break_length="250" color="16" dash_length="2000" dashed="true" shift="70" width="140"/>
          </borders>
        </line_symbol>
      </symbol>
      
      <symbol code="506.1.4" id="91" name="Unpaved footpath or track, non-urban, 0.55mm width" type="2">
        <description>An unpaved footpath or rough vehicle track is a way for passing mainly by foot, without a smooth, hard surface. The density of the brown fill-in shall be the same as the density chosen for the symbol (529).

To improve the legibility of this symbol in non-urban parts of the map, the line width shall, in the non-urban parts of the map, be increased from 0.07 mm to 0.14 mm, and the brown fill-in shall, in the non-urban parts of the map, be drawn darker, so that if (x)% brown is used in urban parts of the map, (x+20)% brown shall be used in the non-urban parts of the map.

Colour: black, brown 0%(white), 10%, 20% or 30% (urban) / 20%, 30%, 40%, 50% (min.60lines/cm) (non-urban); the colour and the line width shall be the same as for the symbols paved area (529) and step or edge of paved areas (529.1).</description>
        <line_symbol break_length="250" cap_style="0" color="14" dash_length="2000" dashes_in_group="1" end_length="0" end_offset="0" in_group_break_length="500" join_style="1" line_width="550" mid_symbol_distance="0" mid_symbols_per_spot="1" minimum_length="0" minimum_mid_symbol_count="0" minimum_mid_symbol_count_when_closed="0" segment_length="4000" show_at_least_one_symbol="true" start_offset="0">
          <borders>
            <border break_length="250" color="16" dash_length="2000" dashed="true" shift="70" width="140"/>
          </borders>
        </line_symbol>
      </symbol>
      
      <symbol code="507" id="92" name="Small unpaved footpath or track" type="2">
        <description>A small unpaved footpath or track. Not to be used in urban areas.</description>
        <line_symbol break_length="250" cap_style="0" color="2" dash_length="1000" dashed="true" dashes_in_group="1" end_length="0" end_offset="0" in_group_break_length="500" join_style="1" line_width="180" mid_symbol_distance="0" mid_symbols_per_spot="1" minimum_length="0" minimum_mid_symbol_count="0" minimum_mid_symbol_count_when_closed="0" segment_length="4000" show_at_least_one_symbol="true" start_offset="0"/>
      </symbol>
      
      <symbol code="508" id="93" name="Less distinct small path" type="2">
        <description>A less distinct path or forestry extraction track. Not to be used in urban areas.</description>
        <line_symbol break_length="1000" cap_style="0" color="2" dash_length="1000" dashed="true" dashes_in_group="2" end_length="0" end_offset="0" in_group_break_length="250" join_style="1" line_width="180" mid_symbol_distance="0" mid_symbols_per_spot="1" minimum_length="0" minimum_mid_symbol_count="0" minimum_mid_symbol_count_when_closed="0" segment_length="4000" show_at_least_one_symbol="true" start_offset="0"/>
      </symbol>
      
      <symbol code="509" id="94" name="Narrow ride" type="2">
        <description>A distinct ride is a linear break in the forest (usually in a plantation), which does not have a distinct path along it. Where there is a path along a ride, the symbol small unpaved footpath or track (506.1) shall be used. Not to be used in urban areas.</description>
        <line_symbol break_length="500" cap_style="0" color="2" dash_length="3000" dashed="true" dashes_in_group="1" end_length="0" end_offset="0" in_group_break_length="500" join_style="1" line_width="140" mid_symbol_distance="0" mid_symbols_per_spot="1" minimum_length="0" minimum_mid_symbol_count="0" minimum_mid_symbol_count_when_closed="0" segment_length="4000" show_at_least_one_symbol="true" start_offset="0"/>
      </symbol>
      
      <symbol code="512.1.1" id="95" name="Bridge, minimum width" type="2">
