        <line_symbol break_length="1000" cap_style="0" color="2" dash_length="4000" dashes_in_group="1" end_length="0" end_offset="0" in_group_break_length="500" join_style="1" line_width="180" mid_symbol_distance="0" mid_symbols_per_spot="1" minimum_length="0" minimum_mid_symbol_count="0" minimum_mid_symbol_count_when_closed="0" segment_length="4000" show_at_least_one_symbol="true" start_offset="0"/>
