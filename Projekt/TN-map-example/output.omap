              <pattern rotation="0">
                <coord x="0" y="0"/>
              </pattern>
            </object>
          </element>
        </point_symbol>
      </symbol>
      
      <symbol code="702" id="154" name="Control point" type="1">
        <description>The control points are shown with circles. The centre of the circle shows the precise position of the feature. Sections of circles should be omitted to leave important detail showing.</description>
        <point_symbol elements="0" inner_color="-1" inner_radius="2825" outer_color="0" outer_width="350"/>
      </symbol>
      
      <symbol code="703" id="155" name="Control number" type="8">
        <description>The number of the control is placed close to the control point circle in such a way that it does not obscure important detail. The numbers are orientated to north.</description>
